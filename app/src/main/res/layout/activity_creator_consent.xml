<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/lumo_background">

    <!-- ══════════════════════════════════════════════════
         GRADIENT HERO HEADER — same pattern as CircleSettingsActivity
         ══════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/heroHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_hero_gradient"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="48dp"
        android:paddingBottom="56dp"
        android:gravity="center">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="@string/creator_consent_step_label"
            android:textColor="#B3FFFFFF"
            android:textSize="11sp"
            android:fontFamily="@font/outfit_semibold"
            android:letterSpacing="0.12" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/creator_consent_title"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:fontFamily="@font/outfit_bold"
            android:letterSpacing="0.01"
            android:gravity="center"
            android:lineSpacingMultiplier="1.2" />

        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/creator_consent_subtitle"
            android:textColor="#B3FFFFFF"
            android:textSize="13sp"
            android:fontFamily="@font/outfit"
            android:gravity="center" />

    </LinearLayout>

    <!-- ══════════════════════════════════════════════════
         SCROLLABLE CONTENT CARD — overlapping the hero gradient
         ══════════════════════════════════════════════════ -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="140dp"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="32dp">

            <!-- White card overlapping gradient -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="-20dp"
                app:cardCornerRadius="32dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="@color/lumo_background">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:paddingTop="32dp"
                    android:paddingBottom="16dp">

                    <!-- ══════════════════════════════════════════════════
                         SECTION 1 — YOUR RESPONSIBILITIES (teal-bordered)
                         ══════════════════════════════════════════════════ -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="1.5dp"
                        app:strokeColor="@color/lumo_tertiary"
                        app:cardBackgroundColor="@color/lumo_tertiary_container">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="12dp"
                                android:text="@string/creator_consent_section_responsibilities_title"
                                android:textColor="@color/lumo_tertiary"
                                android:textSize="12sp"
                                android:fontFamily="@font/outfit_bold"
                                android:letterSpacing="0.08" />

                            <!-- Responsibility item 1 -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:layout_marginBottom="8dp">
                                <TextView
                                    android:layout_width="16dp"
                                    android:layout_height="wrap_content"
                                    android:text="✓"
                                    android:textColor="@color/lumo_tertiary"
                                    android:textSize="13sp"
                                    android:fontFamily="@font/outfit_semibold" />
                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:layout_marginStart="6dp"
                                    android:text="@string/creator_consent_resp_1"
                                    android:textColor="@color/lumo_on_surface"
                                    android:textSize="13sp"
                                    android:fontFamily="@font/outfit"
                                    android:lineSpacingMultiplier="1.3" />
                            </LinearLayout>

                            <!-- Responsibility item 2 -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:layout_marginBottom="8dp">
                                <TextView
                                    android:layout_width="16dp"
                                    android:layout_height="wrap_content"
                                    android:text="✓"
                                    android:textColor="@color/lumo_tertiary"
                                    android:textSize="13sp"
                                    android:fontFamily="@font/outfit_semibold" />
                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:layout_marginStart="6dp"
                                    android:text="@string/creator_consent_resp_2"
                                    android:textColor="@color/lumo_on_surface"
                                    android:textSize="13sp"
                                    android:fontFamily="@font/outfit"
                                    android:lineSpacingMultiplier="1.3" />
                            </LinearLayout>

                            <!-- Responsibility item 3 -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:layout_marginBottom="8dp">
                                <TextView
                                    android:layout_width="16dp"
                                    android:layout_height="wrap_content"
                                    android:text="✓"
                                    android:textColor="@color/lumo_tertiary"
                                    android:textSize="13sp"
                                    android:fontFamily="@font/outfit_semibold" />
                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:layout_marginStart="6dp"
                                    android:text="@string/creator_consent_resp_3"
                                    android:textColor="@color/lumo_on_surface"
                                    android:textSize="13sp"
                                    android:fontFamily="@font/outfit"
                                    android:lineSpacingMultiplier="1.3" />
                            </LinearLayout>

                            <!-- Responsibility item 4 -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">
                                <TextView
                                    android:layout_width="16dp"
                                    android:layout_height="wrap_content"
                                    android:text="✓"
                                    android:textColor="@color/lumo_tertiary"
                                    android:textSize="13sp"
                                    android:fontFamily="@font/outfit_semibold" />
                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:layout_marginStart="6dp"
                                    android:text="@string/creator_consent_resp_4"
                                    android:textColor="@color/lumo_on_surface"
                                    android:textSize="13sp"
                                    android:fontFamily="@font/outfit"
                                    android:lineSpacingMultiplier="1.3" />
                            </LinearLayout>

                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- ══════════════════════════════════════════════════
                         SECTION 2 — IMPORTANT LIMITATIONS (coral/secondary-bordered)
                         ══════════════════════════════════════════════════ -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="1.5dp"
                        app:strokeColor="@color/lumo_secondary"
                        app:cardBackgroundColor="@color/lumo_secondary_container">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="12dp"
                                android:text="@string/creator_consent_section_limitations_title"
                                android:textColor="@color/lumo_secondary"
                                android:textSize="12sp"
                                android:fontFamily="@font/outfit_bold"
                                android:letterSpacing="0.08" />

                            <!-- Limitation item 1 -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:layout_marginBottom="8dp">
                                <TextView
                                    android:layout_width="16dp"
                                    android:layout_height="wrap_content"
                                    android:text="!"
                                    android:textColor="@color/lumo_secondary"
                                    android:textSize="13sp"
                                    android:fontFamily="@font/outfit_bold" />
                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:layout_marginStart="6dp"
                                    android:text="@string/creator_consent_limit_1"
                                    android:textColor="@color/lumo_on_surface"
                                    android:textSize="13sp"
                                    android:fontFamily="@font/outfit"
                                    android:lineSpacingMultiplier="1.3" />
                            </LinearLayout>

                            <!-- Limitation item 2 -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">
                                <TextView
                                    android:layout_width="16dp"
                                    android:layout_height="wrap_content"
                                    android:text="!"
                                    android:textColor="@color/lumo_secondary"
                                    android:textSize="13sp"
                                    android:fontFamily="@font/outfit_bold" />
                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:layout_marginStart="6dp"
                                    android:text="@string/creator_consent_limit_2"
                                    android:textColor="@color/lumo_on_surface"
                                    android:textSize="13sp"
                                    android:fontFamily="@font/outfit"
                                    android:lineSpacingMultiplier="1.3" />
                            </LinearLayout>

                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- ══════════════════════════════════════════════════
                         SECTION 3 — CHECKBOXES CONSENT
                         ══════════════════════════════════════════════════ -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="20dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/lumo_outline_variant"
                        app:cardBackgroundColor="@color/lumo_surface">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <!-- Checkbox 1: Responsibility accepted -->
                            <com.google.android.material.checkbox.MaterialCheckBox
                                android:id="@+id/cbResponsibility"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="12dp"
                                android:text="@string/creator_consent_cb_responsibility"
                                android:enabled="false"
                                android:textColor="@color/lumo_on_surface"
                                android:textSize="13sp"
                                android:fontFamily="@font/outfit"
                                android:lineSpacingMultiplier="1.3"
                                app:buttonTint="@color/lumo_primary" />

                            <!-- Checkbox 2: Emergency understood -->
                            <com.google.android.material.checkbox.MaterialCheckBox
                                android:id="@+id/cbEmergency"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="12dp"
                                android:text="@string/creator_consent_cb_emergency"
                                android:enabled="false"
                                android:textColor="@color/lumo_on_surface"
                                android:textSize="13sp"
                                android:fontFamily="@font/outfit"
                                android:lineSpacingMultiplier="1.3"
                                app:buttonTint="@color/lumo_primary" />

                            <!-- Checkbox 3: Inform members -->
                            <com.google.android.material.checkbox.MaterialCheckBox
                                android:id="@+id/cbInformMembers"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/creator_consent_cb_inform_members"
                                android:enabled="false"
                                android:textColor="@color/lumo_on_surface"
                                android:textSize="13sp"
                                android:fontFamily="@font/outfit"
                                android:lineSpacingMultiplier="1.3"
                                app:buttonTint="@color/lumo_primary" />

                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Helper text under checkboxes -->
                    <TextView
                        android:id="@+id/tvConsentHint"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="24dp"
                        android:text="@string/creator_consent_scroll_hint"
                        android:textColor="@color/lumo_on_surface_muted"
                        android:textSize="12sp"
                        android:fontFamily="@font/outfit"
                        android:gravity="center"
                        android:visibility="visible" />

                    <!-- Primary action button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAcceptCreate"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/button_height"
                        android:text="@string/creator_consent_btn_accept"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:fontFamily="@font/outfit_semibold"
                        android:background="@drawable/bg_btn_primary"
                        android:stateListAnimator="@null"
                        android:enabled="false"
                        app:cornerRadius="28dp"
                        app:elevation="4dp" />

                    <!-- Progress indicator -->
                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/progressBar"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:visibility="gone"
                        android:indeterminate="true"
                        app:indicatorColor="@color/lumo_primary"
                        app:trackColor="@color/lumo_outline_variant"
                        app:trackCornerRadius="4dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
