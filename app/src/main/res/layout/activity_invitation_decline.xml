<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/lumo_background">

    <!-- ══════════════════════════════════════════
         GRADIENT HERO HEADER (raspberry tones via register header)
         ══════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/heroHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_hero_gradient"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="48dp"
        android:paddingBottom="56dp">

        <TextView
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginBottom="12dp"
            android:gravity="center_vertical"
            android:text="@string/common_back"
            android:textColor="#B3FFFFFF"
            android:textSize="13sp"
            android:fontFamily="@font/outfit_semibold"
            android:paddingEnd="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="@string/decline_step_label"
            android:textColor="#B3FFFFFF"
            android:textSize="11sp"
            android:fontFamily="@font/outfit_semibold"
            android:letterSpacing="0.12" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/decline_screen_title"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:fontFamily="@font/outfit_bold"
            android:letterSpacing="0.01"
            android:lineSpacingMultiplier="1.2" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/decline_screen_subtitle"
            android:textColor="#B3FFFFFF"
            android:textSize="13sp"
            android:fontFamily="@font/outfit" />

    </LinearLayout>

    <!-- ══════════════════════════════════════════
         SCROLLABLE CONTENT
         ══════════════════════════════════════════ -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="160dp"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="28dp"
            android:paddingBottom="40dp">

            <!-- ── CONFIRMATION PANEL ──── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardDeclineInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:cardElevation="@dimen/elevation_sm"
                app:cardBackgroundColor="@color/lumo_surface"
                app:strokeColor="@color/lumo_outline_variant"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/tvDeclineQuestion"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:textColor="@color/lumo_on_surface"
                        android:textSize="15sp"
                        android:fontFamily="@font/outfit_semibold"
                        android:lineSpacingMultiplier="1.4" />

                    <TextView
                        android:id="@+id/tvDeclineInfo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/lumo_on_surface_muted"
                        android:textSize="13sp"
                        android:fontFamily="@font/outfit"
                        android:lineSpacingMultiplier="1.4" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ── REASON INPUT CARD ───── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:cardElevation="@dimen/elevation_sm"
                app:cardBackgroundColor="@color/lumo_surface"
                app:strokeColor="@color/lumo_outline_variant"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:text="@string/decline_reason_label"
                        android:textColor="@color/lumo_primary"
                        android:textSize="11sp"
                        android:fontFamily="@font/outfit_bold"
                        android:letterSpacing="0.06"
                        android:textAllCaps="true" />

                    <!-- Suggestion chips row 1 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:id="@+id/chipNotComfortable"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:paddingTop="8dp"
                            android:paddingBottom="8dp"
                            android:layout_marginEnd="6dp"
                            android:text="@string/decline_suggestion_not_comfortable"
                            android:textSize="11sp"
                            android:fontFamily="@font/outfit_semibold"
                            android:background="@drawable/bg_badge_rounded"
                            android:backgroundTint="@color/lumo_surface_variant"
                            android:textColor="@color/lumo_on_surface_muted"
                            android:gravity="center" />

                        <TextView
                            android:id="@+id/chipPreferOther"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:paddingTop="8dp"
                            android:paddingBottom="8dp"
                            android:text="@string/decline_suggestion_prefer_other"
                            android:textSize="11sp"
                            android:fontFamily="@font/outfit_semibold"
                            android:background="@drawable/bg_badge_rounded"
                            android:backgroundTint="@color/lumo_surface_variant"
                            android:textColor="@color/lumo_on_surface_muted"
                            android:gravity="center" />

                    </LinearLayout>

                    <!-- Suggestion chips row 2 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:id="@+id/chipCannotCommit"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:paddingTop="8dp"
                            android:paddingBottom="8dp"
                            android:layout_marginEnd="6dp"
                            android:text="@string/decline_suggestion_cannot_commit"
                            android:textSize="11sp"
                            android:fontFamily="@font/outfit_semibold"
                            android:background="@drawable/bg_badge_rounded"
                            android:backgroundTint="@color/lumo_surface_variant"
                            android:textColor="@color/lumo_on_surface_muted"
                            android:gravity="center" />

                        <TextView
                            android:id="@+id/chipOther"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:paddingTop="8dp"
                            android:paddingBottom="8dp"
                            android:text="@string/decline_suggestion_other"
                            android:textSize="11sp"
                            android:fontFamily="@font/outfit_semibold"
                            android:background="@drawable/bg_badge_rounded"
                            android:backgroundTint="@color/lumo_surface_variant"
                            android:textColor="@color/lumo_on_surface_muted"
                            android:gravity="center" />

                    </LinearLayout>

                    <!-- Optional reason text field -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilReason"
                        style="@style/Widget.Lumo.TextInputLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/decline_reason_field_hint"
                        app:counterEnabled="true"
                        app:counterMaxLength="200">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etReason"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textMultiLine|textCapSentences"
                            android:minLines="2"
                            android:maxLines="4"
                            android:maxLength="200"
                            android:fontFamily="@font/outfit" />

                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ── ERROR BANNER ─────────── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/errorBanner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:visibility="gone"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFF0F3"
                app:strokeColor="#33C25C6E"
                app:strokeWidth="1dp">

                <TextView
                    android:id="@+id/tvError"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="14dp"
                    android:textColor="#C25C6E"
                    android:textSize="12sp"
                    android:fontFamily="@font/outfit_semibold"
                    android:lineSpacingMultiplier="1.4" />

            </com.google.android.material.card.MaterialCardView>

            <!-- ── ACTION BUTTONS ────────── -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnConfirmDecline"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:layout_marginBottom="12dp"
                android:text="@string/decline_btn_confirm"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:fontFamily="@font/outfit_semibold"
                android:background="@drawable/bg_btn_danger"
                android:stateListAnimator="@null"
                app:cornerRadius="28dp"
                app:elevation="4dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancelDecline"
                style="@style/Widget.Lumo.Button.Outlined"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:text="@string/decline_btn_cancel" />

            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/progressBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:visibility="gone"
                android:indeterminate="true"
                app:indicatorColor="@color/lumo_secondary"
                app:trackColor="@color/lumo_outline_variant"
                app:trackCornerRadius="4dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
