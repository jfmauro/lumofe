<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/lumo_background">

    <!-- ══════════════════════════════════════════
         GRADIENT HERO HEADER
         ══════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/heroHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_hero_gradient"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="48dp"
        android:paddingBottom="56dp">

        <!-- Back button — TextView, no icon drawable reference -->
        <TextView
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginBottom="12dp"
            android:gravity="center_vertical"
            android:text="@string/common_back"
            android:textColor="#B3FFFFFF"
            android:textSize="13sp"
            android:fontFamily="@font/outfit_semibold"
            android:paddingStart="0dp"
            android:paddingEnd="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="@string/tracking_step_label"
            android:textColor="#B3FFFFFF"
            android:textSize="11sp"
            android:fontFamily="@font/outfit_semibold"
            android:letterSpacing="0.12" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tracking_title_placeholder"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:fontFamily="@font/outfit_bold"
            android:letterSpacing="0.01"
            android:lineSpacingMultiplier="1.2" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/tracking_subtitle"
            android:textColor="#B3FFFFFF"
            android:textSize="13sp"
            android:fontFamily="@font/outfit" />

    </LinearLayout>

    <!-- ══════════════════════════════════════════
         SCROLLABLE CONTENT
         ══════════════════════════════════════════ -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="160dp"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="28dp"
            android:paddingBottom="32dp">

            <!-- ── STATISTICS CARD ─────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/statsCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:visibility="gone"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:cardElevation="@dimen/elevation_sm"
                app:cardBackgroundColor="@color/lumo_surface"
                app:strokeColor="@color/lumo_outline_variant"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="14dp"
                        android:text="@string/tracking_stats_header"
                        android:textColor="@color/lumo_primary"
                        android:textSize="11sp"
                        android:fontFamily="@font/outfit_bold"
                        android:letterSpacing="0.06"
                        android:textAllCaps="true" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:background="@drawable/bg_stat_pill"
                            android:padding="10dp"
                            android:layout_marginEnd="6dp">

                            <TextView
                                android:id="@+id/tvStatSent"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/lumo_on_surface"
                                android:textSize="13sp"
                                android:fontFamily="@font/outfit_semibold"
                                android:text="@string/tracking_stat_sent_placeholder" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:background="@drawable/bg_stat_pill"
                            android:padding="10dp"
                            android:layout_marginStart="6dp">

                            <TextView
                                android:id="@+id/tvStatAccepted"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/lumo_success"
                                android:textSize="13sp"
                                android:fontFamily="@font/outfit_semibold"
                                android:text="@string/tracking_stat_accepted_placeholder" />

                        </LinearLayout>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:background="@drawable/bg_stat_pill"
                            android:padding="10dp"
                            android:layout_marginEnd="6dp">

                            <TextView
                                android:id="@+id/tvStatPending"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/lumo_warning"
                                android:textSize="13sp"
                                android:fontFamily="@font/outfit_semibold"
                                android:text="@string/tracking_stat_pending_placeholder" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:background="@drawable/bg_stat_pill"
                            android:padding="10dp"
                            android:layout_marginStart="6dp">

                            <TextView
                                android:id="@+id/tvStatMembers"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/lumo_primary"
                                android:textSize="13sp"
                                android:fontFamily="@font/outfit_semibold"
                                android:text="@string/tracking_stat_members_placeholder" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── FILTER TABS (reuse bg_badge_rounded already in project) ─── -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:scrollbars="none"
                android:fillViewport="false">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingEnd="4dp">

                    <TextView
                        android:id="@+id/tabAll"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:layout_marginEnd="6dp"
                        android:text="@string/filter_all"
                        android:textSize="12sp"
                        android:fontFamily="@font/outfit_semibold"
                        android:background="@drawable/bg_badge_rounded"
                        android:backgroundTint="@color/lumo_surface_variant"
                        android:textColor="@color/lumo_on_surface_muted" />

                    <TextView
                        android:id="@+id/tabPending"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:layout_marginEnd="6dp"
                        android:text="@string/filter_pending"
                        android:textSize="12sp"
                        android:fontFamily="@font/outfit_semibold"
                        android:background="@drawable/bg_badge_rounded"
                        android:backgroundTint="@color/lumo_surface_variant"
                        android:textColor="@color/lumo_on_surface_muted" />

                    <TextView
                        android:id="@+id/tabAccepted"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:layout_marginEnd="6dp"
                        android:text="@string/filter_accepted"
                        android:textSize="12sp"
                        android:fontFamily="@font/outfit_semibold"
                        android:background="@drawable/bg_badge_rounded"
                        android:backgroundTint="@color/lumo_surface_variant"
                        android:textColor="@color/lumo_on_surface_muted" />

                    <TextView
                        android:id="@+id/tabDeclined"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:layout_marginEnd="6dp"
                        android:text="@string/filter_refused"
                        android:textSize="12sp"
                        android:fontFamily="@font/outfit_semibold"
                        android:background="@drawable/bg_badge_rounded"
                        android:backgroundTint="@color/lumo_surface_variant"
                        android:textColor="@color/lumo_on_surface_muted" />

                    <TextView
                        android:id="@+id/tabExpired"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:layout_marginEnd="6dp"
                        android:text="@string/filter_expired"
                        android:textSize="12sp"
                        android:fontFamily="@font/outfit_semibold"
                        android:background="@drawable/bg_badge_rounded"
                        android:backgroundTint="@color/lumo_surface_variant"
                        android:textColor="@color/lumo_on_surface_muted" />

                    <TextView
                        android:id="@+id/tabRevoked"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:text="@string/filter_revoked"
                        android:textSize="12sp"
                        android:fontFamily="@font/outfit_semibold"
                        android:background="@drawable/bg_badge_rounded"
                        android:backgroundTint="@color/lumo_surface_variant"
                        android:textColor="@color/lumo_on_surface_muted" />

                </LinearLayout>
            </HorizontalScrollView>

            <!-- ── LOADING INDICATOR ────────────────────────── -->
            <ProgressBar
                android:id="@+id/progressInitial"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="32dp"
                android:indeterminate="true"
                android:indeterminateTint="@color/lumo_primary"
                android:visibility="gone" />

            <!-- ── EMPTY STATE ──────────────────────────────── -->
            <TextView
                android:id="@+id/tvEmptyState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="12dp"
                android:text="@string/tracking_empty_state"
                android:textColor="@color/lumo_on_surface_variant"
                android:textSize="14sp"
                android:fontFamily="@font/outfit"
                android:gravity="center"
                android:paddingTop="16dp"
                android:paddingBottom="16dp"
                android:visibility="gone" />

            <!-- ── INVITATION LIST ──────────────────────────── -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvInvitations"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:visibility="gone" />

            <!-- ── SEND NEW INVITATION BUTTON ──────────────── -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSendInvitation"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:layout_marginTop="24dp"
                android:text="@string/tracking_btn_send_invitation"
                android:fontFamily="@font/outfit_semibold"
                android:textSize="15sp"
                android:textColor="@color/white"
                app:backgroundTint="@color/lumo_primary"
                app:cornerRadius="@dimen/button_corner_radius" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
