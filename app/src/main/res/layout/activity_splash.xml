<?xml version="1.0" encoding="utf-8"?>
<!--
    KEY CHANGES vs main:
    - Background: sc_background (cream) -> bg_splash_gradient (dark caramel)
    - tvAnchorIcon (anchor emoji) removed — replaced by ImageView logo + bicolor wordmark
    - Decorative orbs added
    - Fonts: system sans-serif -> Outfit Bold
    - Animation targets: logoContainer / taglineContainer must match SplashActivity.kt references
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_splash_gradient">

    <!-- Decorative orb top: caramel -->
    <View
        android:id="@+id/decorOrbTop"
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:alpha="0.18"
        android:background="@drawable/bg_glow_orb_primary"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toTopOf="@id/logoContainer"
        app:layout_constraintVertical_bias="0.0" />

    <!-- Decorative orb bottom: sage -->
    <View
        android:id="@+id/decorOrbBottom"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:alpha="0.12"
        android:background="@drawable/bg_glow_orb_tertiary"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.95" />

    <!-- Logo container — animated by SplashActivity: fade_slide_up -->
    <LinearLayout
        android:id="@+id/logoContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintBottom_toTopOf="@id/taglineContainer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed"
        app:layout_constraintVertical_bias="0.44">

        <ImageView
            android:id="@+id/ivLogo"
            android:layout_width="@dimen/lumo_mark_size"
            android:layout_height="@dimen/lumo_mark_size"
            android:src="@drawable/ic_launcher_foreground"
            android:contentDescription="@string/cd_lumo_logo"
            android:scaleType="fitCenter" />

        <!-- Wordmark: "Lu" dim + "mo" white -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal"
            android:baselineAligned="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lu"
                android:textColor="#E8DDD0"
                android:textSize="42sp"
                android:fontFamily="@font/outfit_bold"
                android:letterSpacing="-0.04" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="mo"
                android:textColor="#FFFFFF"
                android:textSize="42sp"
                android:fontFamily="@font/outfit_bold"
                android:letterSpacing="-0.04" />

        </LinearLayout>

    </LinearLayout>

    <!-- Tagline container — animated by SplashActivity: fade_in_delayed -->
    <LinearLayout
        android:id="@+id/taglineContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:layout_marginTop="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/logoContainer"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintVertical_bias="0.0">

        <TextView
            android:id="@+id/tvTagline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_tagline"
            android:textColor="#B3FFFFFF"
            android:textSize="13sp"
            android:fontFamily="@font/outfit"
            android:textStyle="italic"
            android:gravity="center" />

    </LinearLayout>

    <!-- Loading indicator -->
    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/progressSplash"
        android:layout_width="120dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="64dp"
        android:indeterminate="true"
        app:trackColor="#33FFFFFF"
        app:indicatorColor="@color/white"
        app:trackCornerRadius="4dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
