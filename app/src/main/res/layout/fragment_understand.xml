<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_cream"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="40dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="28dp"
            android:paddingEnd="28dp"
            android:paddingTop="16dp"
            android:paddingBottom="4dp">

            <TextView
                android:id="@+id/tv_concept_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="13dp"
                android:text="@string/concept_title"
                android:textColor="#C8855A"
                android:textSize="14sp"
                android:fontFamily="@font/outfit_bold"
                android:letterSpacing="0.06"
                android:textAllCaps="true" />

            <TextView
                android:id="@+id/tv_concept_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/concept_subtitle"
                android:fontFamily="@font/outfit_regular"
                android:textSize="14sp"
                android:textColor="@color/muted"/>

        </LinearLayout>

        <!-- Feature list -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="20dp">

            <!-- Feature 1: Check-in -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_feature_item_default"
                android:padding="16dp"
                android:elevation="2dp">

                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_feature_icon_sage"
                    android:padding="6dp"
                    android:src="@drawable/ic_feature_checkin"
                    android:contentDescription="@string/concept_feature1_title"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/concept_feature1_title"
                        android:fontFamily="@font/outfit_semibold"
                        android:textSize="14sp"
                        android:textColor="@color/charcoal"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/concept_feature1_desc"
                        android:fontFamily="@font/outfit_regular"
                        android:textSize="12sp"
                        android:textColor="@color/muted"
                        android:lineSpacingMultiplier="1.4"/>

                </LinearLayout>

            </LinearLayout>

            <!-- Feature 2: Alertes -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_feature_item_default"
                android:padding="16dp"
                android:layout_marginTop="14dp"
                android:elevation="2dp">

                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_feature_icon_raspberry"
                    android:padding="6dp"
                    android:src="@drawable/ic_feature_alert"
                    android:contentDescription="@string/concept_feature2_title"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/concept_feature2_title"
                        android:fontFamily="@font/outfit_semibold"
                        android:textSize="14sp"
                        android:textColor="@color/charcoal"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/concept_feature2_desc"
                        android:fontFamily="@font/outfit_regular"
                        android:textSize="12sp"
                        android:textColor="@color/muted"
                        android:lineSpacingMultiplier="1.4"/>

                </LinearLayout>

            </LinearLayout>

            <!-- Feature 3: Coordination -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_feature_item_default"
                android:padding="16dp"
                android:layout_marginTop="14dp"
                android:elevation="2dp">

                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_feature_icon_caramel"
                    android:padding="6dp"
                    android:src="@drawable/ic_feature_circle"
                    android:contentDescription="@string/concept_feature3_title"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/concept_feature3_title"
                        android:fontFamily="@font/outfit_semibold"
                        android:textSize="14sp"
                        android:textColor="@color/charcoal"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/concept_feature3_desc"
                        android:fontFamily="@font/outfit_regular"
                        android:textSize="12sp"
                        android:textColor="@color/muted"
                        android:lineSpacingMultiplier="1.4"/>

                </LinearLayout>

            </LinearLayout>

            <!-- Feature 4: Confidentialité (gradient background) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_feature_item_privacy"
                android:padding="16dp"
                android:layout_marginTop="14dp">

                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_feature_icon_caramel"
                    android:padding="6dp"
                    android:src="@drawable/ic_feature_privacy"
                    android:contentDescription="@string/concept_feature4_title"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/concept_feature4_title"
                        android:fontFamily="@font/outfit_semibold"
                        android:textSize="14sp"
                        android:textColor="@color/charcoal"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/concept_feature4_desc"
                        android:fontFamily="@font/outfit_regular"
                        android:textSize="12sp"
                        android:textColor="@color/muted"
                        android:lineSpacingMultiplier="1.4"/>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>




    </LinearLayout>

</androidx.core.widget.NestedScrollView>