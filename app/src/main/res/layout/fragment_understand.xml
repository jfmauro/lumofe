<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:paddingTop="16dp"
        android:paddingBottom="24dp">

        <!-- title_l: Playfair Display 26sp -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/understand_title"
            android:textColor="#2D2420"
            android:textSize="26sp"
            android:fontFamily="@font/playfair_display_medium"
            android:lineSpacingMultiplier="1.2"
            android:maxLines="2" />

        <!-- body_m muted -->
        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="20dp"
            android:text="@string/understand_subtitle"
            android:textColor="#B0A090"
            android:textSize="13sp"
            android:fontFamily="@font/outfit"
            android:lineSpacingMultiplier="1.4" />

        <!-- Feature card 1: Check-in — sage -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardFeature1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            style="@style/Widget.Lumo.FeatureCard">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <FrameLayout
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_feature_icon_green">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="✓"
                        android:textColor="#7A9E8E"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:contentDescription="@string/cd_check_feature" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/understand_feature1_title"
                        android:textColor="#2D2420"
                        android:textSize="14sp"
                        android:fontFamily="@font/playfair_display_semibold"
                        android:lineSpacingMultiplier="1.3" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/understand_feature1_desc"
                        android:textColor="#B0A090"
                        android:textSize="12sp"
                        android:fontFamily="@font/outfit"
                        android:lineSpacingMultiplier="1.4" />
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Feature card 2: Alerts — raspberry -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardFeature2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            style="@style/Widget.Lumo.FeatureCard">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <FrameLayout
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_feature_icon_orange">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="🔔"
                        android:textSize="20sp"
                        android:contentDescription="@string/cd_alert_feature" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/understand_feature2_title"
                        android:textColor="#2D2420"
                        android:textSize="14sp"
                        android:fontFamily="@font/playfair_display_semibold"
                        android:lineSpacingMultiplier="1.3" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/understand_feature2_desc"
                        android:textColor="#B0A090"
                        android:textSize="12sp"
                        android:fontFamily="@font/outfit"
                        android:lineSpacingMultiplier="1.4" />
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Feature card 3: Circle — caramel -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardFeature3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            style="@style/Widget.Lumo.FeatureCard">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <FrameLayout
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_feature_icon_teal">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="🤝"
                        android:textSize="20sp"
                        android:contentDescription="@string/cd_circle_feature" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/understand_feature3_title"
                        android:textColor="#2D2420"
                        android:textSize="14sp"
                        android:fontFamily="@font/playfair_display_semibold"
                        android:lineSpacingMultiplier="1.3" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/understand_feature3_desc"
                        android:textColor="#B0A090"
                        android:textSize="12sp"
                        android:fontFamily="@font/outfit"
                        android:lineSpacingMultiplier="1.4" />
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Feature card 4: Privacy — caramel (new card, DSL FEATURE_PRIVACY_*) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardFeature4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/Widget.Lumo.FeatureCard">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <FrameLayout
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_feature_icon_teal">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="🔒"
                        android:textSize="20sp"
                        android:contentDescription="@null" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/understand_feature_privacy_title"
                        android:textColor="#2D2420"
                        android:textSize="14sp"
                        android:fontFamily="@font/playfair_display_semibold"
                        android:lineSpacingMultiplier="1.3" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/understand_feature_privacy_desc"
                        android:textColor="#B0A090"
                        android:textSize="12sp"
                        android:fontFamily="@font/outfit"
                        android:lineSpacingMultiplier="1.4" />
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</ScrollView>
