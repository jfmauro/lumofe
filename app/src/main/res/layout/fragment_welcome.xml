<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_hero_gradient">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- HERO AREA: DSL LumoMark + Wordmark + title_xl + tagline + ProgressDots -->
        <LinearLayout
            android:id="@+id/heroArea"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingStart="32dp"
            android:paddingEnd="32dp"
            android:paddingTop="24dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@id/ctaArea"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Lumo mark 96dp -->
            <ImageView
                android:id="@+id/ivLumoMark"
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:layout_gravity="center_horizontal"
                android:src="@drawable/ic_launcher_foreground"
                android:contentDescription="@string/cd_lumo_logo" />

            <!-- Wordmark "Lu" brown-mid + "mo" caramel -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:orientation="horizontal"
                android:baselineAligned="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Lu"
                    android:textColor="#6B4F3A"
                    android:textSize="42sp"
                    android:fontFamily="@font/outfit_bold"
                    android:letterSpacing="-0.04" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="mo"
                    android:textColor="#C8855A"
                    android:textSize="42sp"
                    android:fontFamily="@font/outfit_bold"
                    android:letterSpacing="-0.04" />

            </LinearLayout>

            <!-- display_xl: DM Serif Display 35sp, text_secondary -->
            <TextView
                android:id="@+id/tvWelcomeTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/welcome_title"
                android:textColor="#6B4F3A"
                android:textSize="35sp"
                android:fontFamily="@font/dm_serif_display"
                android:lineSpacingMultiplier="1.1"
                android:gravity="center"
                android:maxLines="2" />

            <!-- body_m italic, text_disabled -->
            <TextView
                android:id="@+id/tvWelcomeTagline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="32dp"
                android:text="@string/welcome_subtitle"
                android:textColor="#9C7B63"
                android:textSize="13sp"
                android:fontFamily="@font/outfit"
                android:textStyle="italic"
                android:gravity="center" />

            <!-- DSL ProgressDots: 4 dots, dot 0 active -->
            <LinearLayout
                android:id="@+id/progressDots"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <View android:layout_width="20dp" android:layout_height="6dp"
                    android:background="@drawable/ic_step_dot_active"
                    android:layout_marginEnd="6dp" />
                <View android:layout_width="6dp" android:layout_height="6dp"
                    android:background="@drawable/ic_step_dot_inactive"
                    android:layout_marginEnd="6dp" />
                <View android:layout_width="6dp" android:layout_height="6dp"
                    android:background="@drawable/ic_step_dot_inactive"
                    android:layout_marginEnd="6dp" />
                <View android:layout_width="6dp" android:layout_height="6dp"
                    android:background="@drawable/ic_step_dot_inactive" />

            </LinearLayout>

        </LinearLayout>

        <!-- CTA AREA: PrimaryButton + SecondaryButton -->
        <!-- Note: buttons are ALSO present in activity_onboarding.xml bottom sheet.
             This layout is used when the fragment fills the full screen independently.
             When hosted in OnboardingActivity, ctaArea is hidden (visibility=gone) and
             the activity's bottom sheet buttons are used instead. -->
        <LinearLayout
            android:id="@+id/ctaArea"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="28dp"
            android:paddingEnd="28dp"
            android:paddingTop="24dp"
            android:paddingBottom="40dp"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCreateCircle"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/welcome_btn_create"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:fontFamily="@font/outfit_semibold"
                android:background="@drawable/bg_btn_primary"
                android:stateListAnimator="@null"
                app:cornerRadius="28dp"
                app:elevation="4dp" />

            <Space android:layout_width="match_parent" android:layout_height="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnJoinInvitation"
                style="@style/Widget.Lumo.Button.Outlined"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/welcome_btn_invitation" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
