<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        Night mode — minimal override.
        The DSL does not define a dark palette for MVP0.
        We keep the same warm surface colors; future dark mode work can expand this.
    -->
    <style name="Theme.Lumo" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/lumo_primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/lumo_primary_container</item>
        <item name="colorOnPrimaryContainer">@color/lumo_on_primary_container</item>
        <item name="colorSecondary">@color/lumo_secondary</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSecondaryContainer">@color/lumo_secondary_container</item>
        <item name="colorOnSecondaryContainer">@color/lumo_on_secondary_container</item>
        <item name="colorTertiary">@color/lumo_tertiary</item>
        <item name="colorOnTertiary">@color/white</item>
        <item name="colorError">@color/lumo_error</item>
        <item name="android:colorBackground">@color/lumo_background</item>
        <item name="colorSurface">@color/lumo_surface</item>
        <item name="colorOnSurface">@color/lumo_on_surface</item>
        <item name="colorOnSurfaceVariant">@color/lumo_on_surface_muted</item>
        <item name="android:statusBarColor">@color/lumo_background</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:textColorPrimary">@color/lumo_on_surface</item>
        <item name="android:textColorSecondary">@color/lumo_on_surface_muted</item>
        <item name="android:fontFamily">@font/outfit</item>
        <item name="materialButtonStyle">@style/Widget.Lumo.Button.Primary</item>
        <item name="textInputStyle">@style/Widget.Lumo.TextInputLayout</item>
    </style>
</resources>
